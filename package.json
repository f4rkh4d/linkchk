{
  "name": "linkchk",
  "version": "0.1.0",
  "description": "fast parallel link checker for markdown and html. ci-friendly, single binary via bun",
  "keywords": [
    "markdown",
    "link-checker",
    "cli",
    "ci",
    "bun",
    "html",
    "dead-links",
    "docs"
  ],
  "license": "MIT",
  "author": "farkhad <bennett@frkhd.com>",
  "homepage": "https://github.com/f4rkh4d/linkchk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f4rkh4d/linkchk.git"
  },
  "bugs": {
    "url": "https://github.com/f4rkh4d/linkchk/issues"
  },
  "bin": {
    "linkchk": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "start": "bun run src/cli.ts",
    "test": "bun test",
    "build": "bun build --compile --minify src/cli.ts --outfile=dist/linkchk",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
